.env
.env.local
.env.*.local
ai_service/.env

# Dependencies
/vendor/
ai_service/.venv/
node_modules/

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Runtime storage (keep structure, not user data)
storage/uploads/ids/*
!storage/uploads/ids/.htaccess
!storage/uploads/ids/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/temp/*
!storage/temp/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
!storage/logs/audit/.gitkeep
storage/logs/*.log
storage/logs/audit/*.log
storage/logs/*.lock

# XAMPP/OS
.DS_Store
Thumbs.db
desktop.ini

