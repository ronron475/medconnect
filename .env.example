# MedConnect AI interpreter (Step 2 medical translation enhancement)
# Copy to system environment or set in XAMPP Apache env / start_ai_service.bat

# Base URL override (optional)
# If unset, MedConnect derives the origin from the current request host
# so it works automatically for:
# - http://localhost/medconnect
# - http://192.168.x.x/medconnect
# - https://<ngrok-subdomain>.ngrok-free.app/medconnect
# - https://your-production-domain.tld
#
# Example (required for production video on phones):
# MEDCONNECT_APP_URL=https://your-domain.tld/medconnect
MEDCONNECT_APP_URL=

# Trust reverse-proxy headers for scheme/host detection (ngrok, cloud proxies).
# Set to false only if you are behind an untrusted proxy that can spoof headers.
MEDCONNECT_TRUST_PROXY=true

# Session SameSite policy: Lax (recommended), Strict, or None (requires HTTPS).
MEDCONNECT_SESSION_SAMESITE=Lax

# Primary: Groq (llama-3.3-70b-versatile)
GROQ_API_KEY=

# Optional: OpenAI fallback
OPENAI_API_KEY=

# Optional: local Llama via Ollama
MEDCONNECT_LOCAL_LLAMA_URL=http://127.0.0.1:11434
MEDCONNECT_LOCAL_LLAMA_MODEL=llama3

# Provider order (comma-separated): groq, openai, local
MEDCONNECT_AI_PROVIDER_ORDER=groq,openai,local

# Set to 0 to disable AI layer (dictionary-only translation)
MEDCONNECT_AI_INTERPRETER=1

MEDCONNECT_GROQ_MODEL=llama-3.3-70b-versatile
# Optional faster model for demo/registration NLP (~2x quicker Groq step):
# MEDCONNECT_GROQ_MODEL=llama-3.1-8b-instant
MEDCONNECT_OPENAI_MODEL=gpt-4o-mini
MEDCONNECT_AI_INTERPRETER_TIMEOUT=25

# Python AI microservice (required for NLP demo — no silent PHP fallback when REQUIRE_PYTHON=true)
# URL of ai_service/server.py when deployed separately
MEDCONNECT_AI_SERVICE_URL=http://127.0.0.1:8765
# Set to false on shared hosting (uses PHP validation workflow only)
MEDCONNECT_AI_SERVICE_ENABLED=true
# Set to false in production so web requests never spawn Python locally
MEDCONNECT_AI_AUTO_START=true
MEDCONNECT_AI_HEALTH_TIMEOUT=3
MEDCONNECT_AI_ANALYZE_TIMEOUT=120
# When true (default), analyze API returns 503 instead of PHP fallback if Python is unavailable
MEDCONNECT_AI_REQUIRE_PYTHON=true

# FastAPI OCR — unified on main AI service (port 8765)
# MEDCONNECT_OCR_SERVICE_URL defaults to MEDCONNECT_AI_SERVICE_URL
MEDCONNECT_OCR_SERVICE_ENABLED=true
MEDCONNECT_OCR_TIMEOUT=90
OCR_SPACE_API_KEY=
