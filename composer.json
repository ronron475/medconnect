{
    "name": "medconnect/platform",
    "description": "MedConnect — community healthcare and teleconsultation platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "phpmailer/phpmailer": "^6.9"
