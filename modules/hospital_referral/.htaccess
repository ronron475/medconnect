# =============================================================================
# .htaccess — Hospital Referral Module
# Works on Apache shared hosting (cPanel, Hostinger, GoDaddy, etc.)
# =============================================================================

Options -Indexes

# ── PHP file security ─────────────────────────────────────────────────────────
# Block direct access to config file
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# ── Force HTTPS on live servers ───────────────────────────────────────────────
# Comment out this block if your host handles HTTPS at the load balancer level
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow localhost without redirect
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
    RewriteCond %{HTTPS} off [NC]
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(self)"
    # Allow geolocation on your own origin (required for HTTPS deployments)
    Header always set Feature-Policy "geolocation 'self'"
</IfModule>

# ── Cache static assets ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css              "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png             "access plus 30 days"
</IfModule>

# ── Compress responses ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Block access to hidden files ──────────────────────────────────────────────
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
